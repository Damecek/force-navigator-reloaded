{
  "name": "force-navigator-reloaded",
  "version": "5.10.5",
  "scripts": {
    "build": "rm -rf dist && webpack --mode production",
    "dev-build": "webpack --mode development",
    "dev": "webpack --mode development --watch",
    "lint": "eslint \"src/**/*.js\"",
    "lint-fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.{js,json,md,html}\"",
    "bump": "npm version minor --no-git-tag-version && node ./scripts/syncManifestVersion.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@lwc/eslint-plugin-lwc": "^3.5.0",
    "@lwc/eslint-plugin-lwc-platform": "^6.3.0",
    "@lwc/module-resolver": "^9.1.1",
    "@salesforce/eslint-config-lwc": "^4.1.2",
    "@salesforce/eslint-plugin-lightning": "^2.0.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "husky": "^9.1.7",
    "lwc": "^9.1.1",
    "lwc-webpack-plugin": "^3.1.0",
    "prettier": "^3.8.1",
    "terser-webpack-plugin": "^5.4.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "lint-staged": {
    "*.{js,json,md,html}": "prettier --write"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@webcomponents/custom-elements": "^1.6.0",
    "codemirror": "^6.0.2"
  }
}
